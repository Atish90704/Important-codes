#include<bits/stdc++.h>
using namespace std;

int removeElement(int* nums, int numsSize, int val) {
    for(int i=0;i<numsSize;i++){
        if(nums[i]==val){
            for(int j=i;j<numsSize;j++){
                nums[j]=nums[j+1];
            }
            numsSize--;
            i--;
        }
    }
    return numsSize;
}

int main()
{
    int a[]={2,5,1,4,2,3,1,4,3,5,1,1,8};
    int siz=removeElement(a,sizeof(a)/sizeof(a[0]),1);
    for(int i=0;i<siz;i++){
        cout<<a[i]<<" ";
    }
    cout<<"Size: "<<siz;
    return 0;
}

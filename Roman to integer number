#include<bits/stdc++.h>
using namespace std;
class Solution {
    int ch[26]={0};
public:
    int value(int i)
    {
        int r;
        if(i==0) r=4;
        if(i==1) r=9;
        if(i==2) r=100;
        if(i==3) r=500;
        if(i==4) r=40;
        if(i==5) r=90;
        if(i==6) r=400;
        if(i==7) r=900;
        if(i==8) r=1;
        if(i==11) r=50;
        if(i==12) r=1000;
        if(i==21) r=5;
        if(i==23) r=10;
        return r;
    }
    int num=0, q;
    int romanToInt(string s) {
        int siz=s.size();
        for(int i=0;i<siz-1;i++){
            //1
            if(s[i]=='I' && s[i+1]=='V'){
                s[i]='A';
                for(int j=i+1;j<siz-1;j++){
                    s[j]=s[j+1];
                }
                siz--;
            }
            //2
            if(s[i]=='I' && s[i+1]=='X'){
                s[i]='B';
                for(int j=i+1;j<siz-1;j++){
                    s[j]=s[j+1];
                }
                siz--;
            }
            //3
            if(s[i]=='X' && s[i+1]=='L'){
                s[i]='E';
                for(int j=i+1;j<siz-1;j++){
                    s[j]=s[j+1];
                }
                siz--;
            }
            //4
            if(s[i]=='X' && s[i+1]=='C'){
                s[i]='F';
                for(int j=i+1;j<siz-1;j++){
                    s[j]=s[j+1];
                }
                siz--;
            }
            //5
            if(s[i]=='C' && s[i+1]=='D'){
                s[i]='G';
                for(int j=i+1;j<siz-1;j++){
                    s[j]=s[j+1];
                }
                siz--;
            }
            //6
            if(s[i]=='C' && s[i+1]=='M'){
                s[i]='H';
                for(int j=i+1;j<siz-1;j++){
                    s[j]=s[j+1];
                }
                siz--;
            }
        }
        for(int i=0;i<siz;i++){
            ch[s[i]-65]++;
        }
        for(int i=0;i<26;i++){
            q=value(i);
            num+=q*ch[i];
        }
        return num;
    }
};
int main()
{
    Solution s;
    cout<<s.romanToInt("MCMXCIV");
    return 0;
}

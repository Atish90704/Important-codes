                parent_e[e.to] = i;
                if (e.to == t) return true;
                q.push(e.to);
            }
        }
    }
    return false;
}

int edmondsKarp(int s, int t) {
    int flow = 0;
    while (bfs(s, t)) {
        int f = INT_MAX;
        for (int v = t; v != s; v = parent_v[v]) {
            int u = parent_v[v];
            f = min(f, graph[u][parent_e[v]].cap);

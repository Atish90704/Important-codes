        for (int v = t; v != s; v = parent_v[v]) {
            int u = parent_v[v];
            Edge &e = graph[u][parent_e[v]];
            e.cap -= f;
            graph[v][e.rev].cap += f;
            e.flow += f;
            graph[v][e.rev].flow -= f;
        }
        flow += f;
    }
    return flow;
}

/* 🔴 MODIFIED: extract one used path from flow graph */
vector<int> extractPath(int s, int t) {
    vector<int> path;
    int u = s;
    path.push_back(u);

    while (u != t) {
        for (auto &e : graph[u]) {
            if (e.flow == 1) {
                e.flow = 0;  // consume this path
                u = e.to;
                path.push_back(u);
                break;
            }
        }
    }
    return path;
}

